{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/minimax-m3",
  "small_model": "opencode-go/deepseek-v4-flash",
  "default_agent": "build",
  "shell": "/bin/zsh",
  "logLevel": "INFO",
  "share": "manual",
  "autoupdate": "notify",
  "snapshot": true,

  "instructions": [
    "AGENTS.md",
    "crates/agentd-protocol/AGENTS.md",
    "crates/agentd-testing/AGENTS.md",
    "xtask/AGENTS.md",
    "docs/style.md"
  ],

  "skills": {
    "paths": [
      ".opencode/skills",
      "docs/superpowers/skills"
    ]
  },

  "references": {
    "docs": {
      "path": "docs",
      "description": "Design docs, ADRs, superpowers specs for agentd"
    },
    "arch": {
      "path": "ARCHITECTURE.md",
      "description": "System architecture overview"
    }
  },

  "permission": {
    "read": "allow",

    "edit": {
      "./**": "allow",
      "*.md": "allow",
      "**/Cargo.toml": "allow",
      "**/Cargo.lock": "allow",
      "**/*.rs": "allow",
      "**/*.toml": "allow",
      "**/*.json": "allow",
      "**/*.jsonc": "allow",
      "**/*.yml": "allow",
      "**/*.yaml": "allow",
      "**/.gitignore": "allow",
      "**/.gitattributes": "allow",
      "~/.ssh/**": "deny",
      "~/.aws/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.docker/**": "deny",
      "~/.kube/**": "deny",
      "~/.config/gh/**": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny",
      "**/secrets.*": "deny",
      "**/*credentials*": "deny",
      "./.nono/profile.json": "deny",
      "./opencode.json": "deny",
      "./opencode.local.json": "deny",
      "../**": "ask",
      "../../**": "ask",
      "*": "ask"
    },

    "bash": {
      "cargo build": "allow",
      "cargo build *": "allow",
      "cargo test": "allow",
      "cargo test *": "allow",
      "cargo check": "allow",
      "cargo check *": "allow",
      "cargo clippy": "allow",
      "cargo clippy *": "allow",
      "cargo fmt": "allow",
      "cargo fmt *": "allow",
      "cargo doc": "allow",
      "cargo doc *": "allow",
      "cargo install *": "deny",
      "cargo uninstall *": "deny",
      "cargo publish *": "deny",
      "rustc *": "allow",
      "rustup show": "allow",
      "rustup show *": "allow",
      "rustup which *": "allow",
      "rustup update *": "deny",
      "rustup default *": "deny",
      "rustup toolchain *": "deny",

      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git blame *": "allow",
      "git fetch": "allow",
      "git fetch *": "allow",
      "git add *": "allow",
      "git add": "allow",
      "git branch": "allow",

      "rg *": "allow",
      "grep *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "ll *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "file *": "allow",
      "find *": "allow",
      "tree *": "allow",
      "pwd": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "date": "allow",
      "which *": "allow",
      "uname *": "allow",

      "rm -rf /": "deny",
      "rm -rf ~": "deny",
      "rm -rf .": "deny",
      "chmod *": "deny",
      "chown *": "deny",
      "chflags *": "deny",
      "xattr *": "deny",

      "nc *": "deny",
      "ncat *": "deny",

      "sudo *": "deny",
      "su *": "deny",
      "doas *": "deny",

      "docker *": "deny",
      "podman *": "deny",
      "kubectl *": "deny",
      "helm *": "deny",
      "terraform *": "deny",

      "cc *": "allow",
      "gcc *": "allow",
      "clang *": "allow",
      "ld *": "allow",
      "ar *": "allow",

      "eval *": "deny",
      "exec *": "deny",

      "vim *": "deny",
      "nano *": "deny",
      "emacs *": "deny",

      "nono why *": "allow",
      "nono status": "allow",
      "nono sessions": "allow",
      "nono profile show *": "allow",
      "*": "ask"
    },

    "external_directory": {
      "./**": "allow",
      "**/agentd*/**": "allow",
      "~/.ssh/**": "deny",
      "~/.aws/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.docker/**": "deny",
      "~/.kube/**": "deny",
      "~/.config/gh/**": "deny",
      "~/.config/opencode/skills/**": "allow",
      "~/.opencode/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.cargo/**": "allow",
      "~/.rustup/**": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/secrets.*": "deny",
      "**/*credentials*": "deny",
      "**/id_rsa": "deny",
      "**/id_ed25519": "deny",
      "*": "ask"
    },

    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "todowrite": "allow",
    "question": "allow",
    "lsp": "allow",
    "doom_loop": "allow",
    "webfetch": "ask",
    "websearch": "ask",
    "skill": "allow"
  },

  "agent": {
    "build": {
      "permission": {
        "edit": "allow",
        "bash": {
          "cargo *": "allow",
          "git status": "allow",
          "git diff": "allow",
          "git log *": "allow",
          "git add *": "allow",
          "git commit *": "ask",
          "rg *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "*": "ask"
        }
      }
    },
    "plan": {
      "permission": {
        "edit": "deny",
        "bash": {
          "cargo check *": "allow",
          "cargo test *": "allow",
          "rg *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "git log *": "allow",
          "git show *": "allow",
          "*": "ask"
        }
      }
    }
  },

  "formatter": false,
  "lsp": {
    "rust": true
  },

  "experimental": {
    "primary_tools": ["edit"],
    "mcp_timeout": 30000
  },

  "tool_output": {
    "max_lines": 2000,
    "max_bytes": 65536
  },

  "compaction": {
    "auto": true,
    "tail_turns": 15
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "default": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "default",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    }
  },
  "model": "default:qwen2.5-coder:7b",
  "agent": {
    "build": {
      "prompt": "{file:./agents/tdd.md}"
    },
    "plan": {
      "prompt": "{file:./agents/planner.md}"
    }
  },
  "ignore": [
    "target/**",
    ".git/**",
    "**/*.rs.bk",
    ".local-data/**"
  ]
}
